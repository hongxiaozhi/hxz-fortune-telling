root = true

[*.md]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = false

[*.py]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.sh]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.ps1]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
